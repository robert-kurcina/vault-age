{
  "rules": [
    {
      "find": "(```[\\s\\S]*?```)|(\\n(?: *\\n)+(?![ \\t]*(?:---|#|```)))",
      "replace": "[[KP_BLOCK]]",
      "flags": "gm",
      "shouldProtect": true
    },
    {
      "find": "^[ \\t]*([a-zA-Z0-9+#-]+)(?:[ \\t]*\\n)+([ \\t]*```)",
      "replace": "$2$1",
      "flags": "gm",
      "shouldProtect": false,
      "toLower": true
    },
    {
      "find": "````\\n",
      "replace": "",
      "flags": "gm",
      "shouldProtect": false,
      "toLower": false
    },
    {
      "find": "(?<!\\`)\\b([a-zA-Z0-9\\-_]+(?:\\.[a-zA-Z0-9\\-_]+)*\\.[a-zA-Z0-9]{2,})\\b(?!\\`)",
      "replace": "`$1`",
      "flags": "g",
      "shouldProtect": false,
      "toLower": false
    },
    {
      "find": "([^|\\n])\\n(\\|.*)",
      "replace": "$1\\n\\n$2",
      "flags": "gm",
      "shouldProtect": false,
      "toLower": false
    },
    {
      "find": "\\|(?=[^\\|\\s])",
      "replace": "| ",
      "flags": "gm",
      "shouldProtect": false,
      "toLower": false
    },
    {
      "find": "(?<=[^\\|\\s])\\|",
      "replace": " |",
      "flags": "gm",
      "shouldProtect": false,
      "toLower": false
    }
  ]
}