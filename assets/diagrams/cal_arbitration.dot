digraph G {
  graph [rankdir=TB, bgcolor="white", pad="0.25", nodesep="0.30", ranksep="0.38"];
  node [shape=box, style="rounded,filled", fillcolor="#f7f7f7", color="#444444", fontname="DejaVu Sans", fontsize=11, margin="0.10,0.06"];
  edge [color="#555555", arrowsize=0.65];
  q[label="Natural-language Question"];
  interp[label="Query Interpretation"];
  part[label="Partition Selection"];
  ret[label="Source Retrieval"];
  lmsg[label="LMS-Graph\nsource substrate", fillcolor="#eef4ff"];
  weigh[label="Authority + Version Weighting"];
  conflict[label="Conflict Surfacing"];
  env[label="Arbitration Envelope"];
  human[label="Human Decision Point"];
  log[label="Ruling Log"];
  q->interp->part->ret->weigh->conflict->env->human->log;
  ret->lmsg; lmsg->weigh;
}
