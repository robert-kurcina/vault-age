digraph G {
  graph [rankdir=TB, bgcolor="white", pad="0.25", nodesep="0.30", ranksep="0.38"];
  node [shape=box, style="rounded,filled", fillcolor="#f7f7f7", color="#444444", fontname="DejaVu Sans", fontsize=11, margin="0.10,0.06"];
  edge [color="#555555", arrowsize=0.65];
  scaffold[label="World Scaffold"];
  trigger[label="Actualization Trigger"];
  proposal[label="Overlay Proposal"];
  bridge[label="Bridge Layer Validation"];
  contradiction[label="Contradiction Check", fillcolor="#fff7e6"];
  delta[label="State Delta"];
  canon[label="Versioned Canonical Detail"];
  scaffold->trigger->proposal->bridge->delta->canon;
  bridge->contradiction; contradiction->bridge;
}
